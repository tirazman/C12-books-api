# .env.example  (and copy to .env) 
DB_HOST=127.0.0.1 
DB_PORT=3306 
DB_NAME=books_api 
DB_USER=root 
DB_PASS= 
DB_CHARSET=utf8mb4 
APP_DEBUG=true
OGIN_RATE_LIMIT=5 
LOGIN_WINDOW_SECONDS=60 
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
# Add your JWT security configurations here
JWT_SECRET=super_secret_key_change_this_to_something_long_and_secure
JWT_TTL=3600
JWT_ISSUER=books-api